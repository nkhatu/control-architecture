{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "payment-status-response.schema.json",
  "title": "PaymentStatusResponse",
  "type": "object",
  "required": ["payment_id", "status", "updated_at"],
  "properties": {
    "payment_id": { "type": "string" },
    "status": {
      "type": "string",
      "enum": [
        "received",
        "validated",
        "awaiting_approval",
        "approved",
        "released",
        "settlement_pending",
        "settled",
        "failed",
        "cancelled",
        "pending_reconcile",
        "exception"
      ]
    },
    "rail": { "type": "string" },
    "updated_at": { "type": "string", "format": "date-time" },
    "error_class": { "type": "string" },
    "explanation": { "type": "string" }
  },
  "additionalProperties": false
}
